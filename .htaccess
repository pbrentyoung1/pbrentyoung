# pbrentyoung.com — blog, feed, sitemap, and robots routes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# The editorial homepage now lives at the canonical root URL.
RewriteCond %{THE_REQUEST} \s/+index(?:-new)?\.(?:html|php)(?:[?\s]) [NC]
RewriteRule ^index(?:-new)?\.(?:html|php)$ / [R=301,L,NE]

# One canonical index URL: /blog
RewriteCond %{THE_REQUEST} \s/+blog\.html(?:[?\s]) [NC]
RewriteRule ^blog\.html$ /blog [R=301,L,NE]
RewriteCond %{THE_REQUEST} \s/+blog/(?:[?\s]) [NC]
RewriteRule ^blog/$ /blog [R=301,L,NE]

# This essay was folded into Change vs. Polish.
RewriteRule ^blog/you-cant-polish-your-way-into-relevance/?$ /blog/change-vs-polish [R=301,L,NE]

# One canonical reference URL: /glossary
RewriteCond %{THE_REQUEST} \s/+glossary/(?:[?\s]) [NC]
RewriteRule ^glossary/$ /glossary [R=301,L,NE]
RewriteRule ^glossary$ glossary.php [L,QSA]

RewriteRule ^blog$ blog.php [L,QSA]
RewriteRule ^blog/([a-z0-9][a-z0-9-]*)/?$ blog-post.php?slug=$1 [L,QSA]
RewriteRule ^future-congregation-journey$ future-congregation-journey.php [L,QSA]
RewriteRule ^feed\.xml$ feed.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]
</IfModule>
